{
  "name": "jest-chance",
  "version": "0.1.11",
  "description": "Random seed generator for chancejs with jest",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "sideEffects": true,
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meza/jest-chance.git"
  },
  "license": "MIT",
  "scripts": {
    "clean:githooks": "lefthook uninstall -k",
    "ci": "pnpm test && pnpm check:package",
    "clean": "rimraf dist .cache",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "pnpm lint && vitest run --coverage && pnpm build",
    "build": "pnpm clean && tsc -p tsconfig.json && tsc -p tsconfig-cjs.json && node scripts/finalize-package.mjs",
    "check:package": "pnpm build && node scripts/check-package.mjs && publint --strict --pack npm && attw --pack . && npm pack --dry-run --json",
    "semantic-release": "semantic-release",
    "release": "semantic-release"
  },
  "dependencies": {
    "chance": "^1.1.13"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^2.5.3",
    "@commitlint/config-conventional": "^21.0.0",
    "@meza/biome": "^1.3.3",
    "@meza/tsconfig-base": "^1.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/npm": "^13.1.5",
    "@types/chance": "^1.1.8",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "commitlint": "^21.0.0",
    "install-deps-postmerge": "^2.0.1",
    "lefthook": "^2.0.0",
    "pnpm": "^11.13.0",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.7",
    "semantic-release-export-data": "^1.2.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
