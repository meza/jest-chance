{
  "name": "jest-chance",
  "version": "0.1.11",
  "description": "Random seed generator for chancejs with jest",
  "exports": {
    "types": "./dist/types/index.d.ts",
    "import": "./dist/esm/index.js",
    "require": "./dist/cjs/index.js"
  },
  "files": [
    "dist/"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "private": false,
  "repository": "https://github.com/meza/jest-chance",
  "license": "MIT",
  "scripts": {
    "clean:githooks": "lefthook uninstall -k",
    "ci": "pnpm test && pnpm build",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "pnpm lint && vitest run --coverage && pnpm build",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig-cjs.json",
    "semantic-release": "semantic-release",
    "release": "semantic-release"
  },
  "dependencies": {
    "chance": "^1.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/config-conventional": "^14.1.0",
    "@meza/biome": "^1.3.3",
    "@meza/tsconfig-base": "^1.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/npm": "^13.1.5",
    "@types/chance": "^1.1.8",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "commitlint": "^19.8.1",
    "install-deps-postmerge": "^2.0.1",
    "lefthook": "^1.13.6",
    "pnpm": "^11.13.0",
    "semantic-release": "^25.0.7",
    "semantic-release-export-data": "^1.2.0",
    "typescript": "^4.9.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
